# Optional: prefill your deployed factory (no secrets here)
VITE_FACTORY_ADDRESS=0xYourEscrowFactoryOnPolygon
# Optional: target chain. 80002 = Polygon Amoy, 137 = Polygon PoS.
VITE_CHAIN_ID=80002
# Optional: prefill the other party when you always test with the same freelancer wallet
VITE_DEFAULT_FREELANCER=0xOptionalFreelancerAddress
